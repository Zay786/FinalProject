{
  "version": 2,
  "builds": [
    {
      "src": "Backend/vercel.js",
      "use": "@vercel/node"
    },
    {
      "src": "ml-service/api/vercel_quotation_api.py",
      "use": "@vercel/python"
    }
  ],
  "installCommand": "npm install --prefix frontend && npm install --prefix Backend",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/api/ml/:path*",
      "destination": "/ml-service/api/vercel_quotation_api.py"
    },
    {
      "source": "/api/:path*",
      "destination": "/Backend/vercel.js"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
