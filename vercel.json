{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "Backend/vercel.js",
      "use": "@vercel/node"
    },
    {
      "src": "ml-service/api/vercel_quotation_api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/ml/(.*)",
      "dest": "ml-service/api/vercel_quotation_api.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "Backend/vercel.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
